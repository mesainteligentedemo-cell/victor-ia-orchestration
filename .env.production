# ============================================================
# ORCHESTRATION BACKEND — .env.production
# Deploy target: https://orchestration-backend.vercel.app
# Set these in: Vercel Dashboard > Project > Settings > Environment Variables
# (Vercel ignores .env.production files at runtime — this is the source-of-truth template)
# ============================================================

# --- Required ---
ANTHROPIC_API_KEY=sk_...
NODE_ENV=production
VERCEL=true
LOG_LEVEL=info

# --- CORS (allow the SaaS frontend origin) ---
CORS_ORIGIN=https://victor-ia-saas.vercel.app

# --- Optional MCP / integrations (set only if used in production) ---
# FIGMA_API_TOKEN=
# GOOGLE_API_TOKEN=
# ELEVENLABS_API_TOKEN=
# HIGGSFIELD_API_TOKEN=

# --- Runtime config (serverless-safe defaults) ---
# PORT is managed by Vercel — do not set it.
WS_HEARTBEAT_INTERVAL=30000
SESSION_TIMEOUT=3600000
MAX_SESSIONS_ACTIVE=5

# --- Config paths (relative — local FS paths like C:\Users\... do NOT exist on Vercel) ---
PROYECTOS_CONFIG_PATH=./config/PROYECTOS_CONFIG.json
AGENTES_CONFIG_PATH=./config/AGENTES_CONFIG.json
SKILLS_CONFIG_PATH=./config/SKILLS_CONFIG.json
MCP_CONFIG_PATH=./config/MCP_CONFIG.json
ROUTING_RULES_PATH=./config/ROUTING_RULES.json