# === Orchestration Hub Configuration ===

# Server
PORT=3000
NODE_ENV=development

# Anthropic API
# IMPORTANT: an Anthropic key starts with "sk-ant-...". Do NOT paste an
# ElevenLabs key (sk_...) here -> causes 401 "invalid x-api-key".
# The account also needs a positive credit balance (Console > Plans & Billing).
ANTHROPIC_API_KEY=sk-ant-your_real_key_here

# MCP Server Tokens
FIGMA_API_TOKEN=your_figma_token_here
GOOGLE_API_TOKEN=your_google_token_here
ELEVENLABS_API_TOKEN=your_elevenlabs_token_here
HIGGSFIELD_API_TOKEN=your_higgsfield_token_here

# Logging
LOG_LEVEL=info

# Paths
PROYECTOS_CONFIG_PATH=./config/PROYECTOS_CONFIG.json
AGENTES_CONFIG_PATH=./config/AGENTES_CONFIG.json
SKILLS_CONFIG_PATH=./config/SKILLS_CONFIG.json
MCP_CONFIG_PATH=./config/MCP_CONFIG.json
ROUTING_RULES_PATH=./config/ROUTING_RULES.json

# Memory
MEMORIA_PATH=C:\Users\inbou\.claude\projects\c--Users-inbou--agents\memory
PUNTO_PARADA_PATH=C:\Users\inbou\.claude\memoria-sesiones\punto-de-parada.md
PROYECTO_ACTIVO_PATH=C:\Users\inbou\.claude\memoria-sesiones\proyecto-activo.json

# Deep Learning
BUENOS_EJEMPLOS_PATH=C:\Users\inbou\.claude\deep-learning\buenos-ejemplos.md
MALOS_EJEMPLOS_PATH=C:\Users\inbou\.claude\deep-learning\malos-ejemplos.md

# WebSocket
WS_HEARTBEAT_INTERVAL=30000

# Session
SESSION_TIMEOUT=3600000
MAX_SESSIONS_ACTIVE=5
